# Used by the frontend at build time (sitemap, robots) to know the canonical URL
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# REQUIRED: Used by next.config.mjs to proxy /api/* requests to the backend
# Set this to your deployed backend URL (e.g. Railway, Render, etc.)
# For local development: BACKEND_URL=http://localhost:5000
BACKEND_URL=https://your-backend.railway.app
