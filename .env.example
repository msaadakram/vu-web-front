# Canonical site URL — used by sitemap.ts, robots.ts, and OpenGraph/canonical URLs in pages.
# This is a NEXT_PUBLIC_ var, so it is inlined at BUILD time. Set it before `next build`
# and rebuild if it changes.
NEXT_PUBLIC_BASE_URL=https://www.virtualupk.vercel.app

# REQUIRED: Backend API origin (server-only, NOT exposed to the browser).
# Consumed by:
#   - next.config.mjs `rewrites()` (build time) to proxy client-side /api/* calls
#   - server components in app/(app)/blog/[slug] and app/(app)/news/[slug]
#   - app/sitemap.ts
# next.config.mjs throws if this is unset, so it must always be set.
#   - Local dev: copy this file to .env.local and set BACKEND_URL=http://localhost:5000
#   - Production (Heroku/Vercel): set BACKEND_URL to your deployed backend URL (e.g. https://vu-web-backend.herokuapp.com)
BACKEND_URL=https://your-backend.herokuapp.com

# Optional legacy fallback for the canonical base URL in slug pages (defaults to NEXT_PUBLIC_BASE_URL).
# BLOG_PUBLIC_BASE_URL=https://www.virtualupk.vercel.app

# On-demand revalidation: shared secret the backend sends to /api/revalidate
# after publishing/deleting a blog or news post, so the sitemap and listing
# pages refresh immediately. Must match the backend's REVALIDATE_TOKEN.
# If unset, the endpoint refuses all calls (safe default).
REVALIDATE_TOKEN=generate_a_long_random_string

# Optional: Google Search Console verification token (rendered into a
# <meta name="google-site-verification"> tag in the root layout).
# GOOGLE_SITE_VERIFICATION=
